# ── Ollama ────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# Model for creative writing (generator, style_matcher)
OLLAMA_MODEL_WRITE=llama3.1:8b

# Model for structured/JSON output (router LLM fallback, evaluator, LTM extractor)
OLLAMA_MODEL_PRECISE=qwen2.5:7b

# Model for fast routing classification
OLLAMA_MODEL_ROUTER=llama3.2:3b

# Embedding model (768 dims)
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── PostgreSQL ────────────────────────────────────────────────────────────
# Docker command to start:
# docker run --name pa-postgres \
#   -e POSTGRES_USER=postgres -e POSTGRES_PASSWORD=postgres \
#   -e POSTGRES_DB=postgres -p 5442:5432 -d postgres:16
POSTGRES_HOST=localhost
POSTGRES_PORT=5442
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── STM (Short-Term Memory) ───────────────────────────────────────────────
# Keep this many recent messages verbatim before summarizing older ones
STM_WINDOW_SIZE=6

# Summarize when total messages exceed this count
STM_SUMMARIZE_AFTER=10

# ── LTM (Long-Term Memory) ────────────────────────────────────────────────
# Max facts to extract per conversation turn
LTM_MAX_FACTS_PER_TURN=8

# How many facts to retrieve per query
LTM_RETRIEVAL_LIMIT=8

# Cosine similarity threshold for pgvector retrieval (0.0–1.0)
LTM_SIMILARITY_THRESHOLD=0.60

# Cosine similarity threshold for deduplication (higher = stricter)
LTM_DEDUP_THRESHOLD=0.92

# ── Router ────────────────────────────────────────────────────────────────
# Minimum confidence for LLM router decision (0.0–1.0)
# Below this, falls back to "chat"
ROUTER_MIN_CONFIDENCE=0.70

# ── Web Search ────────────────────────────────────────────────────────────
# Max search results to fetch per query
WEB_SEARCH_MAX_RESULTS=5

# Max results to scrape full content from (rest get snippet only)
WEB_SEARCH_SCRAPE_TOP_N=2

# Recency window in days for open_book mode
WEB_OPEN_BOOK_RECENCY_DAYS=7

# Recency window in days for hybrid mode
WEB_HYBRID_RECENCY_DAYS=45

# ── Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
